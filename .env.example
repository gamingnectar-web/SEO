PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
MONGODB_URI=

# Optional normal dashboard login bootstrap
ADMIN_EMAIL=admin@gamingnectar.com
ADMIN_PASSWORD=change-this-password

# Shopify installed app auth
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_content,read_themes
SHOPIFY_APP_URL=http://localhost:3000

# Default tracking config
DEFAULT_SITE_URL=https://www.gamingnectar.com/
DEFAULT_TRACKED_KEYWORDS=pokemon cards uk,booster boxes uk,gaming energy drink,healthy energy drink
DEFAULT_COMPETITORS=

# Google Search Console / keyword context, optional initially
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SITE_URL=https://www.gamingnectar.com/

# SERP/rank/CPC providers, optional initially
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=

# Optional richer AI recommendations
OPENAI_API_KEY=

# Scheduler
ENABLE_SCHEDULER=true
AUDIT_SCHEDULE_CRON=0 */12 * * *
SCHEDULED_AUDIT_MAX_URLS=50