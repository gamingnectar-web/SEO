<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title || "Site Quality Auditor" %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <main class="app-shell">
      <aside class="side-nav">
        <div class="brand">Site Quality Auditor</div>
        <a href="/dashboard">Dashboard</a>
        <a href="/todos">To-dos</a>
        <a href="/keywords">Keywords</a>
        <a class="active" href="/audit">Audits</a>

        <form method="POST" action="/logout" class="side-logout">
          <button type="submit">Log out</button>
        </form>
      </aside>

      <section class="app-main">
        <header class="app-header">
          <div>
            <p class="eyebrow">Audit tools</p>
            <h1>Site Quality Auditor</h1>
            <p>
              Run full-site, page-level, or competitor audits. Results are saved
              and fed into the dashboard history.
            </p>
          </div>

          <div class="header-actions">
            <a class="button-link secondary-link" href="/dashboard">
              Back to dashboard
            </a>
          </div>
        </header>

        <% if (error) { %>
          <div class="error"><%= error %></div>
        <% } %>

        <% if (notice) { %>
          <div class="notice"><%= notice %></div>
        <% } %>

        <section class="tool-grid three-tools">
          <article class="card card-accent">
            <div class="card-heading">
              <p class="eyebrow">Full crawl</p>
              <h2>Full-site audit</h2>
              <p>Use a sitemap crawl to discover and audit multiple URLs.</p>
            </div>

            <form method="POST" action="/audit">
              <input type="hidden" name="mode" value="site" />

              <label for="siteUrl">Site URL</label>
              <input
                id="siteUrl"
                name="siteUrl"
                type="url"
                placeholder="https://www.gamingnectar.com/"
                required
              />

              <label for="maxUrls">Maximum URLs</label>
              <input
                id="maxUrls"
                name="maxUrls"
                type="number"
                min="5"
                max="100"
                value="50"
              />

              <button type="submit">Run full-site crawl</button>
            </form>
          </article>

          <article class="card">
            <div class="card-heading">
              <p class="eyebrow">Specific pages</p>
              <h2>Page audit</h2>
              <p>Audit up to 10 specific URLs.</p>
            </div>

            <form method="POST" action="/audit">
              <input type="hidden" name="mode" value="standard" />

              <label for="urls">URLs, one per line</label>
              <textarea
                id="urls"
                name="urls"
                rows="8"
                placeholder="https://www.gamingnectar.com/products/example"
                required
              ></textarea>

              <button type="submit">Run page audit</button>
            </form>
          </article>

          <article class="card card-dark">
            <div class="card-heading">
              <p class="eyebrow">Competition</p>
              <h2>Competitor audit</h2>
              <p>Compare one of your pages against specific competitor pages.</p>
            </div>

            <form method="POST" action="/audit">
              <input type="hidden" name="mode" value="competitor" />

              <label for="primaryUrl">Your page URL</label>
              <input
                id="primaryUrl"
                name="primaryUrl"
                type="url"
                placeholder="https://www.gamingnectar.com/collections/example"
                required
              />

              <label for="competitorUrls">Competitor URLs, one per line</label>
              <textarea
                id="competitorUrls"
                name="competitorUrls"
                rows="6"
                placeholder="https://competitor.com/example"
                required
              ></textarea>

              <button type="submit">Run competitor audit</button>
            </form>
          </article>
        </section>

        <section class="card">
          <div class="section-heading">
            <p class="eyebrow">Static competitors</p>
            <h2>Tracked competitor list</h2>
            <p>
              Add competitors here so future keyword, SEO and GEO comparisons
              have a fixed comparison set. If you leave tracked URLs blank, the
              app will try to scan the competitor sitemap automatically.
            </p>
          </div>

          <form method="POST" action="/competitors">
            <input type="hidden" name="returnTo" value="/audit" />

            <label for="domain">Competitor domain</label>
            <input
              id="domain"
              name="domain"
              type="text"
              placeholder="competitor.com"
              required
            />

            <label for="trackedUrls">Tracked URLs, one per line</label>
            <textarea
              id="trackedUrls"
              name="urls"
              rows="5"
              placeholder="https://competitor.com/page-a"
            ></textarea>

            <button type="submit">Track and scan competitor</button>
          </form>
        </section>

        <% if (trackedCompetitors && trackedCompetitors.length) { %>
          <section class="card">
            <div class="section-heading row-heading">
              <div>
                <p class="eyebrow">Competitors</p>
                <h2>Current competitor set</h2>
              </div>

              <form method="POST" action="/competitors/snapshot">
                <input type="hidden" name="returnTo" value="/audit" />
                <button
                  type="submit"
                  class="icon-action-button scan-action"
                  title="Scan all competitors"
                  aria-label="Scan all competitors"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 7V4h3M17 4h3v3M20 17v3h-3M7 20H4v-3" />
                    <path d="M7 12h10" />
                    <path d="M9 9h6v6H9z" />
                  </svg>
                  <span>Scan all</span>
                </button>
              </form>
            </div>

            <div class="data-table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Domain</th>
                    <th>Tracked URLs</th>
                    <th>Latest scan</th>
                    <th>Score</th>
                    <th>Issues</th>
                    <th>Pages</th>
                    <th>Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% trackedCompetitors.forEach(function(competitor) {
                    const latestSnapshot = (competitorSnapshots || []).find(function(snapshot) {
                      return snapshot.domain === competitor.domain;
                    });
                  %>
                    <tr>
                      <td>
                        <strong><%= competitor.domain %></strong>
                      </td>

                      <td>
                        <%= competitor.urls?.length || 0 %>
                        <% if (!competitor.urls || !competitor.urls.length) { %>
                          <small>Auto sitemap scan</small>
                        <% } %>
                      </td>

                      <td>
                        <% if (latestSnapshot) { %>
                          <%= latestSnapshot.createdAt ? new Date(latestSnapshot.createdAt).toLocaleString("en-GB") : "—" %>
                          <small><%= latestSnapshot.crawlMode || "scan" %></small>
                        <% } else { %>
                          <span class="muted">Not scanned yet</span>
                        <% } %>
                      </td>

                      <td>
                        <% if (latestSnapshot) { %>
                          <strong><%= latestSnapshot.averageScore || 0 %>/10</strong>
                        <% } else { %>
                          <span class="muted">—</span>
                        <% } %>
                      </td>

                      <td>
                        <% if (latestSnapshot) { %>
                          <%= latestSnapshot.issueCount || 0 %>
                        <% } else { %>
                          <span class="muted">—</span>
                        <% } %>
                      </td>

                      <td>
                        <% if (latestSnapshot) { %>
                          <%= latestSnapshot.pageCount || 0 %>
                          <% if (latestSnapshot.discoveredCount) { %>
                            <small><%= latestSnapshot.discoveredCount %> discovered</small>
                          <% } %>
                        <% } else { %>
                          <span class="muted">—</span>
                        <% } %>
                      </td>

                      <td class="table-actions icon-table-actions">
                        <form method="POST" action="/competitors/snapshot">
                          <input type="hidden" name="returnTo" value="/audit" />
                          <input type="hidden" name="domain" value="<%= competitor.domain %>" />
                          <button
                            type="submit"
                            class="icon-only-button scan-icon"
                            title="Scan competitor"
                            aria-label="Scan competitor"
                          >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path d="M4 7V4h3M17 4h3v3M20 17v3h-3M7 20H4v-3" />
                              <path d="M7 12h10" />
                              <path d="M9 9h6v6H9z" />
                            </svg>
                          </button>
                        </form>

                        <form method="POST" action="/competitors/delete">
                          <input type="hidden" name="returnTo" value="/audit" />
                          <input type="hidden" name="domain" value="<%= competitor.domain %>" />
                          <button
                            type="submit"
                            class="icon-only-button delete-icon"
                            title="Remove competitor"
                            aria-label="Remove competitor"
                          >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path d="M6 6l12 12M18 6L6 18" />
                            </svg>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>

        <% if (recentRuns && recentRuns.length) { %>
          <section class="recent-runs">
            <div class="section-heading">
              <p class="eyebrow">Saved audits</p>
              <h2>Recent audit runs</h2>
            </div>

            <div class="recent-run-list">
              <% recentRuns.forEach(function(run) { %>
                <a class="recent-run-card" href="/audit/<%= run._id %>">
                  <div>
                    <span><%= run.type %></span>
                    <strong><%= run.summary?.averageScore || 0 %>/10</strong>
                  </div>

                  <p>
                    <%= run.summary?.pageCount || 0 %> pages ·
                    <%= run.summary?.issueCount || 0 %> issues
                  </p>

                  <small>
                    <%= run.createdAt ? new Date(run.createdAt).toLocaleString("en-GB") : "—" %>
                  </small>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>
      </section>
    </main>
  </body>
</html>