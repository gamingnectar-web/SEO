<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Gaming Nectar Intelligence</p>
          <h1>SEO, GEO & Site Quality Dashboard</h1>
          <p>
            Crawl your site, score individual pages, compare competitors, and
            break issues into SEO, GEO, technical, linking, content, trust,
            conversion and merchandising tabs.
          </p>

          <div class="hero-pills">
            <span>Full-site crawl</span>
            <span>GEO</span>
            <span>SEO</span>
            <span>Technical</span>
            <span>Linking</span>
            <span>Content</span>
            <span>Competitors</span>
          </div>
        </div>

        <div class="hero-panel">
          <span class="panel-number">10</span>
          <span class="panel-label">Audit areas</span>
          <p>
            Built to become a proper MongoDB-backed monitoring dashboard next.
          </p>
        </div>
      </section>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <section class="tool-grid three-tools">
        <article class="card card-accent">
          <div class="card-heading">
            <p class="eyebrow">Recommended</p>
            <h2>Full-site crawl</h2>
            <p>
              Enter your homepage. The app will read your sitemap and audit up
              to 100 URLs.
            </p>
          </div>

          <form method="POST" action="/audit">
            <input type="hidden" name="mode" value="site" />

            <label for="siteUrl">Site URL</label>
            <input
              id="siteUrl"
              name="siteUrl"
              type="text"
              placeholder="https://www.gamingnectar.com"
            />

            <label for="maxUrls">Maximum URLs</label>
            <input
              id="maxUrls"
              name="maxUrls"
              type="number"
              min="5"
              max="100"
              value="50"
            />

            <button type="submit">Run full-site crawl</button>
          </form>
        </article>

        <article class="card">
          <div class="card-heading">
            <p class="eyebrow">Page audit</p>
            <h2>Audit selected URLs</h2>
            <p>
              Paste specific URLs when you want to inspect key pages manually.
            </p>
          </div>

          <form method="POST" action="/audit">
            <input type="hidden" name="mode" value="standard" />

            <label for="urls">URLs, one per line</label>

            <textarea
              id="urls"
              name="urls"
              rows="8"
              placeholder="https://www.gamingnectar.com/&#10;https://www.gamingnectar.com/products/example"
            ></textarea>

            <button type="submit">Run page audit</button>
          </form>
        </article>

        <article class="card card-dark">
          <div class="card-heading">
            <p class="eyebrow">Competitor analysis</p>
            <h2>Compare competitors</h2>
            <p>
              Add your page and up to five competitor URLs to see where they are
              stronger.
            </p>
          </div>

          <form method="POST" action="/audit">
            <input type="hidden" name="mode" value="competitor" />

            <label for="primaryUrl">Your page URL</label>
            <input
              id="primaryUrl"
              name="primaryUrl"
              type="text"
              placeholder="https://www.gamingnectar.com/products/example"
            />

            <label for="competitorUrls">Competitor URLs</label>
            <textarea
              id="competitorUrls"
              name="competitorUrls"
              rows="6"
              placeholder="https://competitor.com/product-example&#10;https://anothercompetitor.com/product-example"
            ></textarea>

            <button type="submit">Run competitor analysis</button>
          </form>
        </article>
      </section>
    </main>
  </body>
</html>