<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page auth-page">
      <section class="hero compact-hero">
        <div class="hero-copy">
          <p class="eyebrow">SEO Intelligence</p>
          <h1>Create your account</h1>
          <p>Use this if you are accessing the platform outside Shopify.</p>
        </div>
      </section>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <section class="tool-grid two-tools">
        <article class="card card-accent">
          <div class="card-heading">
            <p class="eyebrow">Standard access</p>
            <h2>Sign up</h2>
          </div>

          <form method="POST" action="/signup">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />

            <label for="password">Password</label>
            <input id="password" name="password" type="password" minlength="8" required />

            <label for="siteUrl">Website URL</label>
            <input id="siteUrl" name="siteUrl" type="url" placeholder="https://www.example.com" />

            <button type="submit">Create account</button>
          </form>

          <p class="muted">Already have an account? <a href="/login">Log in</a>.</p>
        </article>

        <article class="card card-dark">
          <div class="card-heading">
            <p class="eyebrow">Shopify merchant?</p>
            <h2>Install through Shopify</h2>
            <p>If you are a Shopify merchant, use the Shopify install flow instead of creating a password account.</p>
          </div>

          <form method="GET" action="/auth/shopify">
            <label for="shop">Shopify shop domain</label>
            <input id="shop" name="shop" type="text" placeholder="your-store.myshopify.com" />
            <button type="submit">Connect Shopify store</button>
          </form>
        </article>
      </section>
    </main>
  </body>
</html>