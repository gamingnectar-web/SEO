<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>
    <main class="app-shell">
      <aside class="side-nav">
        <div class="brand">Site Quality Auditor</div>
        <a class="active" href="/dashboard">Dashboard</a>
        <a href="/todos">To-dos</a>
        <a href="/keywords">Keywords</a>
        <a href="/audit">Audits</a>

        <form method="POST" action="/logout" class="side-logout">
          <button type="submit">Log out</button>
        </form>
      </aside>

      <section class="app-main">
        <header class="app-header">
          <div>
            <p class="eyebrow">Live intelligence</p>
            <h1>SEO Intelligence Dashboard</h1>
            <p>Trace 12-hour audit movement, competitor changes, keyword value, and planned action impact.</p>
          </div>
          <div class="header-stat">
            <strong><%= timeline?.length || 0 %></strong>
            <span>Snapshots</span>
          </div>
        </header>

        <section class="summary-strip">
          <article class="metric-card">
            <span>Open tasks</span>
            <strong><%= todoSummary?.active || 0 %></strong>
          </article>
          <article class="metric-card">
            <span>Planned</span>
            <strong><%= todoSummary?.planned || 0 %></strong>
          </article>
          <article class="metric-card">
            <span>Keywords</span>
            <strong><%= keywordSnapshots?.length || 0 %></strong>
          </article>
          <article class="metric-card">
            <span>Audits</span>
            <strong><%= recentRuns?.length || 0 %></strong>
          </article>
        </section>

        <section class="card knowledge-card insight-<%= insight.status %>">
          <p class="eyebrow">What changed?</p>
          <h2><%= insight.title %></h2>
          <p><%= insight.message %></p>

          <% if (insight.actions?.length) { %>
            <ul>
              <% insight.actions.forEach(function(action) { %>
                <li><%= action %></li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <section class="card">
          <div class="section-heading">
            <p class="eyebrow">Traceability</p>
            <h2>Effectiveness over time</h2>
            <p>Each point is an audit snapshot. Scheduled checks run every 12 hours when the scheduler is enabled.</p>
          </div>
          <canvas id="effectivenessChart" height="120"></canvas>
        </section>

        <section class="tool-grid three-tools">
          <article class="card card-accent">
            <div class="card-heading">
              <p class="eyebrow">Manual control</p>
              <h2>Run now</h2>
              <p>Run the scheduled audit workflow manually.</p>
            </div>
            <form method="POST" action="/dashboard/run-scheduled-now">
              <button type="submit">Run scheduled checks now</button>
            </form>
          </article>

          <article class="card">
            <div class="card-heading">
              <p class="eyebrow">Audit tools</p>
              <h2>Run audit</h2>
              <p>Open the manual page, site and competitor audit forms.</p>
            </div>
            <a class="button-link" href="/audit">Open audit tools</a>
          </article>

          <article class="card card-dark">
            <div class="card-heading">
              <p class="eyebrow">Latest value</p>
              <h2>Keyword value</h2>
              <% const latestKeyword = keywordSnapshots && keywordSnapshots[0]; %>
              <p>
                <% if (latestKeyword) { %>
                  Latest tracked keyword: <strong><%= latestKeyword.keyword %></strong>, estimated paid value £<%= latestKeyword.equivalentPaidValue || 0 %>.
                <% } else { %>
                  Add keywords to estimate organic value against paid spend.
                <% } %>
              </p>
            </div>
            <a class="button-link secondary-link" href="/keywords">Open keywords</a>
          </article>
        </section>

        <section class="card">
          <div class="section-heading row-heading">
            <div>
              <p class="eyebrow">Priority work</p>
              <h2>To-do preview</h2>
            </div>
            <a href="/todos">View all</a>
          </div>

          <% if (todos && todos.length) { %>
            <div class="todo-preview">
              <% todos.forEach(function(todo) { %>
                <article class="mini-todo priority-<%= todo.priority || 'medium' %>">
                  <span><%= todo.status %></span>
                  <strong><%= todo.checkName || todo.category || "SEO task" %></strong>
                  <p><%= todo.recommendation || todo.message %></p>
                  <small><%= todo.pageUrl || "" %></small>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p>No active to-dos yet. Run an audit and add recommendations into your action list.</p>
          <% } %>
        </section>

        <% if (recentRuns && recentRuns.length) { %>
          <section class="recent-runs">
            <div class="section-heading">
              <p class="eyebrow">History</p>
              <h2>Recent audit runs</h2>
            </div>
            <div class="recent-run-list">
              <% recentRuns.forEach(function(run) { %>
                <a class="recent-run-card" href="/audit/<%= run._id %>">
                  <div>
                    <span><%= run.type %></span>
                    <strong><%= run.summary?.averageScore || 0 %>/10</strong>
                  </div>
                  <p><%= run.summary?.pageCount || 0 %> pages · <%= run.summary?.issueCount || 0 %> issues</p>
                  <small><%= new Date(run.createdAt).toLocaleString("en-GB") %></small>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>
      </section>
    </main>

    <script>
      window.__DASHBOARD_TIMELINE__ = <%- JSON.stringify(timeline || []) %>;
    </script>
    <script src="/dashboard.js"></script>
  </body>
</html>