<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title || "Audit Results" %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <main class="app-shell">
      <aside class="side-nav">
        <div class="brand">Site Quality Auditor</div>
        <a href="/dashboard">Dashboard</a>
        <a href="/todos">To-dos</a>
        <a href="/keywords">Keywords</a>
        <a class="active" href="/audit">Audits</a>

        <form method="POST" action="/logout" class="side-logout">
          <button type="submit">Log out</button>
        </form>
      </aside>

      <section class="app-main">
        <%
          const safeResults = Array.isArray(results) ? results : [];
          const summary = auditRun?.summary || siteAudit?.summary || {};
          const categoryAverages = summary.categoryAverages || {};
          const issueCount = summary.issueCount ?? safeResults.reduce((sum, page) => sum + (Array.isArray(page.issues) ? page.issues.length : 0), 0);
          const pageCount = summary.pageCount ?? safeResults.length;
          const averageScore = summary.averageScore ?? (
            safeResults.length
              ? Math.round((safeResults.reduce((sum, page) => sum + Number(page.overallScore || 0), 0) / safeResults.length) * 10) / 10
              : 0
          );

          const formatDate = function(value) {
            if (!value) return "—";
            try {
              return new Date(value).toLocaleString("en-GB");
            } catch {
              return "—";
            }
          };

          const scoreClass = function(score) {
            const number = Number(score || 0);
            if (number >= 8) return "score-good";
            if (number >= 6) return "score-warning";
            return "score-danger";
          };

          const getPageTitle = function(page) {
            return page.title || page.h1 || page.url || "Untitled page";
          };

          const getPageUrl = function(page) {
            return page.url || page.finalUrl || "";
          };

          const getIssueSeverity = function(issue) {
            return issue.severity || issue.priority || "medium";
          };

          const getIssueCategory = function(issue) {
            return issue.category || issue.type || "general";
          };

          const allIssues = safeResults.flatMap(function(page) {
            return (Array.isArray(page.issues) ? page.issues : []).map(function(issue) {
              return {
                ...issue,
                pageUrl: getPageUrl(page),
                pageTitle: getPageTitle(page)
              };
            });
          });

          const priorityIssues = allIssues
            .slice()
            .sort(function(a, b) {
              const weights = { critical: 4, high: 3, medium: 2, low: 1 };
              return (weights[getIssueSeverity(b)] || 0) - (weights[getIssueSeverity(a)] || 0);
            })
            .slice(0, 20);

          const weakestPages = safeResults
            .slice()
            .sort(function(a, b) {
              return Number(a.overallScore || 0) - Number(b.overallScore || 0);
            })
            .slice(0, 10);

          const categories = [
            "technical",
            "seo",
            "geo",
            "linking",
            "content",
            "accessibility",
            "performance",
            "conversion",
            "trust",
            "merchandising"
          ];
        %>

        <header class="app-header">
          <div>
            <p class="eyebrow">Gaming Nectar Intelligence</p>
            <h1><%= auditRun?.type === "site" ? "Full Site Dashboard" : "Audit Results" %></h1>
            <p>
              <% if (auditRun?._id) { %>
                Saved audit · Run ID: <strong><%= auditRun._id %></strong>
              <% } else { %>
                Live audit report
              <% } %>
            </p>
          </div>

          <div class="header-actions">
            <a class="button-link secondary-link" href="/audit">Run another audit</a>
            <a class="button-link" href="/dashboard">Dashboard</a>
          </div>
        </header>

        <section class="summary-strip">
          <article class="metric-card">
            <span>Average score</span>
            <strong><%= averageScore %>/10</strong>
          </article>

          <article class="metric-card">
            <span>Pages audited</span>
            <strong><%= pageCount %></strong>
          </article>

          <article class="metric-card">
            <span>Total issues</span>
            <strong><%= issueCount %></strong>
          </article>

          <article class="metric-card">
            <span>To-dos</span>
            <strong><%= todoSummary?.total || 0 %></strong>
          </article>
        </section>

        <nav class="audit-tabs">
          <a href="#overview">Overview</a>
          <a href="#geo-aeo">GEO / AEO</a>
          <a href="#seo">SEO</a>
          <a href="#technical">Technical</a>
          <a href="#linking">Linking</a>
          <a href="#content">Content</a>
          <a href="#commercial">Commercial</a>
          <a href="#pages">Pages</a>
          <a href="#todos">To-dos</a>
        </nav>

        <section id="overview" class="card">
          <div class="section-heading">
            <p class="eyebrow">Dashboard</p>
            <h2>Overall performance</h2>
            <p>Category averages are calculated from every audited URL in this run.</p>
          </div>

          <div class="category-score-grid">
            <% categories.forEach(function(category) { %>
              <article class="category-score-card">
                <span><%= category %></span>
                <strong class="<%= scoreClass(categoryAverages[category]) %>">
                  <%= categoryAverages[category] ?? "—" %><%= categoryAverages[category] !== undefined ? "/10" : "" %>
                </strong>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="card">
          <div class="section-heading">
            <p class="eyebrow">Focus areas</p>
            <h2>Weakest pages</h2>
          </div>

          <% if (weakestPages.length) { %>
            <div class="page-card-list">
              <% weakestPages.forEach(function(page) { %>
                <article class="page-result-card">
                  <div>
                    <strong><%= getPageTitle(page) %></strong>
                    <a href="<%= getPageUrl(page) %>" target="_blank" rel="noopener noreferrer"><%= getPageUrl(page) %></a>
                    <small><%= Array.isArray(page.issues) ? page.issues.length : 0 %> issues found</small>
                  </div>
                  <span class="page-score <%= scoreClass(page.overallScore) %>"><%= page.overallScore || 0 %>/10</span>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p>No audited pages found.</p>
          <% } %>
        </section>

        <section class="card">
          <div class="section-heading">
            <p class="eyebrow">Priority</p>
            <h2>Priority issues</h2>
          </div>

          <% if (priorityIssues.length) { %>
            <div class="issue-list">
              <% priorityIssues.forEach(function(issue, index) { %>
                <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                  <div>
                    <span><%= getIssueSeverity(issue) %> · <%= getIssueCategory(issue) %></span>
                    <h3><%= issue.title || issue.checkName || issue.name || "Issue" %></h3>
                    <p><%= issue.message || issue.description || issue.recommendation || "No issue detail was provided." %></p>

                    <% if (issue.recommendation) { %>
                      <strong>Recommendation</strong>
                      <p><%= issue.recommendation %></p>
                    <% } %>

                    <a href="<%= issue.pageUrl %>" target="_blank" rel="noopener noreferrer"><%= issue.pageTitle || issue.pageUrl %></a>
                  </div>

                  <form method="POST" action="/todos">
                    <input type="hidden" name="auditRunId" value="<%= auditRun?._id || "" %>" />
                    <input type="hidden" name="pageUrl" value="<%= issue.pageUrl || "" %>" />
                    <input type="hidden" name="pageTitle" value="<%= issue.pageTitle || "" %>" />
                    <input type="hidden" name="category" value="<%= getIssueCategory(issue) %>" />
                    <input type="hidden" name="checkName" value="<%= issue.title || issue.checkName || issue.name || "Audit issue" %>" />
                    <input type="hidden" name="severity" value="<%= getIssueSeverity(issue) %>" />
                    <input type="hidden" name="message" value="<%= issue.message || issue.description || "" %>" />
                    <input type="hidden" name="recommendation" value="<%= issue.recommendation || issue.message || "" %>" />
                    <input type="hidden" name="source" value="audit" />
                    <input type="hidden" name="returnTo" value="/audit/<%= auditRun?._id || "" %>" />
                    <button type="submit">Add to-do</button>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p>No priority issues found.</p>
          <% } %>
        </section>

        <section id="geo-aeo" class="card">
          <div class="section-heading">
            <p class="eyebrow">GEO / AEO</p>
            <h2>Generative and answer-engine analysis</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["geo", "aeo", "schema", "answer"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "GEO / AEO issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Improve entity clarity, structured data, answer blocks and topical coverage." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="seo" class="card">
          <div class="section-heading">
            <p class="eyebrow">SEO</p>
            <h2>Search optimisation issues</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["seo", "metadata", "indexing", "canonical"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "SEO issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Improve metadata, crawlability, canonical signals and content targeting." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="technical" class="card">
          <div class="section-heading">
            <p class="eyebrow">Technical</p>
            <h2>Technical health</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["technical", "performance", "accessibility"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "Technical issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Improve page speed, crawlability, accessibility and technical consistency." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="linking" class="card">
          <div class="section-heading">
            <p class="eyebrow">Linking</p>
            <h2>Internal-link and link-count analysis</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["linking", "links", "internal links"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "Linking issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Reduce link noise and prioritise commercially useful internal links." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="content" class="card">
          <div class="section-heading">
            <p class="eyebrow">Content</p>
            <h2>Content quality</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["content", "copy", "headings"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "Content issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Add useful, specific and commercially relevant content." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="commercial" class="card">
          <div class="section-heading">
            <p class="eyebrow">Commercial</p>
            <h2>Commercial and merchandising signals</h2>
          </div>

          <div class="issue-list compact">
            <% allIssues.filter(issue => ["commercial", "conversion", "trust", "merchandising"].includes(getIssueCategory(issue))).forEach(function(issue) { %>
              <article class="issue-card severity-<%= getIssueSeverity(issue) %>">
                <span><%= issue.pageTitle %></span>
                <h3><%= issue.title || issue.checkName || "Commercial issue" %></h3>
                <p><%= issue.recommendation || issue.message || "Improve buyability, stock signals, trust, product clarity and user intent satisfaction." %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section id="pages" class="card">
          <div class="section-heading">
            <p class="eyebrow">Pages</p>
            <h2>All audited pages</h2>
          </div>

          <% if (safeResults.length) { %>
            <div class="data-table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Page</th>
                    <th>Score</th>
                    <th>Issues</th>
                    <th>Technical</th>
                    <th>SEO</th>
                    <th>GEO</th>
                    <th>Linking</th>
                    <th>Content</th>
                  </tr>
                </thead>
                <tbody>
                  <% safeResults.forEach(function(page) { %>
                    <tr>
                      <td>
                        <strong><%= getPageTitle(page) %></strong>
                        <br />
                        <a href="<%= getPageUrl(page) %>" target="_blank" rel="noopener noreferrer"><%= getPageUrl(page) %></a>
                      </td>
                      <td><strong><%= page.overallScore || 0 %>/10</strong></td>
                      <td><%= Array.isArray(page.issues) ? page.issues.length : 0 %></td>
                      <td><%= page.categoryScores?.technical ?? "—" %></td>
                      <td><%= page.categoryScores?.seo ?? "—" %></td>
                      <td><%= page.categoryScores?.geo ?? "—" %></td>
                      <td><%= page.categoryScores?.linking ?? "—" %></td>
                      <td><%= page.categoryScores?.content ?? "—" %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p>No page results available.</p>
          <% } %>
        </section>

        <section id="todos" class="card">
          <div class="section-heading">
            <p class="eyebrow">Action plan</p>
            <h2>To-dos from this audit</h2>
          </div>

          <% if (todos && todos.length) { %>
            <div class="todo-board">
              <% todos.forEach(function(todo) { %>
                <article class="todo-card priority-<%= todo.priority || "medium" %>">
                  <div>
                    <span class="status-pill"><%= todo.status %></span>
                    <h3><%= todo.checkName || todo.category || "SEO task" %></h3>
                    <p><%= todo.recommendation || todo.message %></p>
                    <small><%= todo.pageUrl %></small>
                  </div>

                  <form method="POST" action="/todos/<%= todo._id %>/status">
                    <input type="hidden" name="returnTo" value="/audit/<%= auditRun?._id || "" %>" />

                    <label>Status</label>
                    <select name="status">
                      <% ["new", "planned", "in_progress", "blocked", "done", "ignored"].forEach(function(status) { %>
                        <option value="<%= status %>" <%= todo.status === status ? "selected" : "" %>><%= status %></option>
                      <% }) %>
                    </select>

                    <label>Due date</label>
                    <input type="date" name="dueDate" value="<%= todo.dueDate ? new Date(todo.dueDate).toISOString().slice(0, 10) : "" %>" />

                    <button type="submit">Update</button>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p>No to-dos have been added from this audit yet. Use the “Add to-do” buttons in Priority issues.</p>
          <% } %>
        </section>
      </section>
    </main>
  </body>
</html>