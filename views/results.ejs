<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <main class="page">
      <div class="topbar">
        <div>
          <p class="eyebrow">Gaming Nectar Intelligence</p>
          <h1>
            <%= siteAudit ? "Full Site Dashboard" : competitorAnalysis ? "Competitor Dashboard" : "Audit Dashboard" %>
          </h1>
        </div>

        <a class="back-link" href="/">Run another audit</a>
      </div>

      <% if (siteAudit) { %>
        <section class="dashboard-summary">
          <div class="summary-card hero-score">
            <span>Average score</span>
            <strong><%= siteAudit.summary.averageScore %>/10</strong>
            <p><%= siteAudit.summary.totalPages %> pages audited</p>
          </div>

          <div class="summary-card">
            <span>Total issues</span>
            <strong><%= siteAudit.summary.totalIssues %></strong>
            <p>Across all audited URLs</p>
          </div>

          <div class="summary-card">
            <span>Discovered URLs</span>
            <strong><%= siteAudit.discoveredCount %></strong>
            <p>From sitemap crawl</p>
          </div>
        </section>
      <% } %>

      <% if (competitorAnalysis) { %>
        <section class="dashboard-summary">
          <div class="summary-card hero-score">
            <span>Your page</span>
            <strong><%= competitorAnalysis.primaryScore %>/10</strong>
            <p><%= competitorAnalysis.primaryUrl %></p>
          </div>

          <div class="summary-card">
            <span>Competitors</span>
            <strong><%= competitorAnalysis.competitors.length %></strong>
            <p>Compared head-to-head</p>
          </div>
        </section>
      <% } %>

      <nav class="tabs" data-tabs>
        <button class="active" data-tab-button="overview">Overview</button>
        <button data-tab-button="geo">GEO</button>
        <button data-tab-button="seo">SEO</button>
        <button data-tab-button="technical">Technical</button>
        <button data-tab-button="linking">Linking</button>
        <button data-tab-button="content">Content</button>
        <button data-tab-button="commercial">Commercial</button>
        <button data-tab-button="pages">Pages</button>
        <% if (competitorAnalysis) { %>
          <button data-tab-button="competitors">Competitors</button>
        <% } %>
      </nav>

      <section class="tab-panel active" data-tab-panel="overview">
        <div class="section-heading">
          <p class="eyebrow">Dashboard</p>
          <h2>Overall performance</h2>
        </div>

        <div class="category-grid">
          <% const overviewScores = siteAudit ? siteAudit.summary.categoryAverages : averageCategories(results); %>
          <% Object.entries(overviewScores).forEach(function(entry) { %>
            <div class="category-item">
              <div>
                <span><%= formatCategory(entry[0]) %></span>
                <div class="score-bar">
                  <i style="width: <%= entry[1] * 10 %>%"></i>
                </div>
              </div>
              <strong><%= entry[1] %>/10</strong>
            </div>
          <% }) %>
        </div>

        <% if (siteAudit) { %>
          <div class="split-grid">
            <section class="panel">
              <h3>Weakest pages</h3>
              <% siteAudit.summary.weakestPages.forEach(function(page) { %>
                <article class="compact-page-row">
                  <strong><%= page.overallScore %>/10</strong>
                  <div>
                    <p><%= page.title || "Untitled page" %></p>
                    <small><%= page.url %></small>
                  </div>
                </article>
              <% }) %>
            </section>

            <section class="panel">
              <h3>Priority issues</h3>
              <% siteAudit.summary.priorityIssues.forEach(function(issue) { %>
                <article class="compact-issue-row">
                  <span><%= formatCategory(issue.category) %></span>
                  <p><%= issue.message %></p>
                  <small><%= issue.url %></small>
                </article>
              <% }) %>
            </section>
          </div>
        <% } %>
      </section>

      <% ["geo", "seo", "technical", "linking", "content"].forEach(function(category) { %>
        <section class="tab-panel" data-tab-panel="<%= category %>">
          <div class="section-heading">
            <p class="eyebrow">Deep dive</p>
            <h2><%= formatCategory(category) %> analysis</h2>
          </div>
                    <% const improvementPlan = siteAudit?.improvementPlans?.[category] || []; %>

          <% if (improvementPlan.length) { %>
            <section class="improvement-panel">
              <div class="section-heading compact">
                <p class="eyebrow">Priority improvements</p>
                <h3>What to improve first</h3>
              </div>

              <div class="improvement-list">
                <% improvementPlan.forEach(function(item) { %>
                  <article class="improvement-card">
                    <div class="improvement-head">
                      <div>
                        <span class="priority-pill"><%= item.priority.label %></span>
                        <h4><%= item.checkName %></h4>
                      </div>

                      <strong><%= item.count %> pages</strong>
                    </div>

                    <div class="improvement-context">
                      <div>
                        <span>Why it matters</span>
                        <p><%= item.context.why %></p>
                      </div>

                      <div>
                        <span>How to improve</span>
                        <p><%= item.context.how %></p>
                      </div>

                      <div>
                        <span>Example</span>
                        <p><%= item.context.example %></p>
                      </div>
                    </div>

                    <% if (item.affectedPages.length) { %>
                      <details class="affected-pages">
                        <summary>View affected pages</summary>

                        <ul>
                          <% item.affectedPages.forEach(function(page) { %>
                            <li>
                              <strong><%= page.title %></strong>
                              <small><%= page.url %></small>
                              <% if (page.evidence) { %>
                                <em>Evidence: <%= page.evidence %></em>
                              <% } %>
                            </li>
                          <% }) %>
                        </ul>
                      </details>
                    <% } %>
                  </article>
                <% }) %>
              </div>
            </section>
          <% } %>

          <div class="deep-list">
            <% results.forEach(function(result) { %>
              <article class="deep-card">
                <div class="deep-card-head">
                  <div>
                    <p class="url"><%= result.url %></p>
                    <h3><%= result.title || "Untitled page" %></h3>
                  </div>
                  <strong><%= result.categoryScores[category] %>/10</strong>
                </div>

                <div class="checks-list">
                  <% (result.categoryDetails[category] || []).forEach(function(check) { %>
                    <div class="check-row check-<%= check.status %>">
                      <div>
                        <strong><%= check.name %></strong>
                        <p><%= check.message %></p>
                        <% if (check.evidence) { %>
                          <small>Evidence: <%= check.evidence %></small>
                        <% } %>
                      </div>

                      <span><%= check.status %></span>
                    </div>
                  <% }) %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>

      <section class="tab-panel" data-tab-panel="commercial">
        <div class="section-heading">
          <p class="eyebrow">Revenue quality</p>
          <h2>Conversion, trust and merchandising</h2>
        </div>

                <% const commercialPlans = [
          ...(siteAudit?.improvementPlans?.conversion || []),
          ...(siteAudit?.improvementPlans?.trust || []),
          ...(siteAudit?.improvementPlans?.merchandising || [])
        ]; %>

        <% if (commercialPlans.length) { %>
          <section class="improvement-panel">
            <div class="section-heading compact">
              <p class="eyebrow">Priority improvements</p>
              <h3>What to improve first commercially</h3>
            </div>

            <div class="improvement-list">
              <% commercialPlans.slice(0, 12).forEach(function(item) { %>
                <article class="improvement-card">
                  <div class="improvement-head">
                    <div>
                      <span class="priority-pill"><%= item.priority.label %></span>
                      <h4><%= item.checkName %></h4>
                    </div>

                    <strong><%= item.count %> pages</strong>
                  </div>

                  <div class="improvement-context">
                    <div>
                      <span>Why it matters</span>
                      <p><%= item.context.why %></p>
                    </div>

                    <div>
                      <span>How to improve</span>
                      <p><%= item.context.how %></p>
                    </div>

                    <div>
                      <span>Example</span>
                      <p><%= item.context.example %></p>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% } %>

        <% ["conversion", "trust", "merchandising"].forEach(function(category) { %>
          <section class="panel spaced-panel">
            <h3><%= formatCategory(category) %></h3>

            <div class="deep-list">
              <% results.forEach(function(result) { %>
                <article class="deep-card">
                  <div class="deep-card-head">
                    <div>
                      <p class="url"><%= result.url %></p>
                      <h3><%= result.title || "Untitled page" %></h3>
                    </div>
                    <strong><%= result.categoryScores[category] %>/10</strong>
                  </div>

                  <div class="checks-list">
                    <% (result.categoryDetails[category] || []).forEach(function(check) { %>
                      <div class="check-row check-<%= check.status %>">
                        <div>
                          <strong><%= check.name %></strong>
                          <p><%= check.message %></p>
                        </div>
                        <span><%= check.status %></span>
                      </div>
                    <% }) %>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </section>

      <section class="tab-panel" data-tab-panel="pages">
        <div class="section-heading">
          <p class="eyebrow">Page-level evidence</p>
          <h2>All audited pages</h2>
        </div>

        <section class="results-list">
          <% results.forEach(function(result, resultIndex) { %>
            <article class="result-card">
              <div class="result-header">
                <div>
                  <p class="url"><%= result.url %></p>
                  <h2><%= result.title || "Untitled page" %></h2>

                  <% if (result.metaDescription) { %>
                    <p class="meta-description"><%= result.metaDescription %></p>
                  <% } %>
                </div>

                <div class="score-box <%= scoreClass(result.overallScore) %>">
                  <span class="score"><%= result.overallScore %></span>
                  <span class="score-total">/10</span>
                  <span class="score-label"><%= scoreLabel(result.overallScore) %></span>
                </div>
              </div>

              <div class="insight-strip">
                <% result.insights.forEach(function(insight) { %>
                  <div>
                    <span><%= insight.label %></span>
                    <strong><%= insight.value %></strong>
                    <small><%= insight.note %></small>
                  </div>
                <% }) %>
              </div>

              <details class="details">
                <summary>Issues and recommendations</summary>

                <% if (result.issues.length) { %>
                  <ul class="issue-list">
                    <% result.issues.forEach(function(issue) { %>
                      <li class="severity-<%= issue.severity %>">
                        <div>
                          <span class="issue-category"><%= formatCategory(issue.category) %></span>
                          <strong><%= issue.severity %></strong>
                        </div>

                        <p class="issue-message"><%= issue.message %></p>

                        <% if (issue.recommendation) { %>
                          <p class="issue-recommendation"><%= issue.recommendation %></p>
                        <% } %>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p>No major issues detected.</p>
                <% } %>
              </details>
            </article>
          <% }) %>
        </section>
      </section>

      <% if (competitorAnalysis) { %>
        <section class="tab-panel" data-tab-panel="competitors">
          <div class="section-heading">
            <p class="eyebrow">Competitor gaps</p>
            <h2>Where competitors are stronger</h2>
          </div>

          <div class="opportunity-list">
            <% competitorAnalysis.comparison.opportunities.forEach(function(item) { %>
              <article>
                <span><%= formatCategory(item.category) %></span>
                <p><%= item.message %></p>
                <small><%= item.competitorUrl %></small>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>
    </main>

    <script src="/app.js"></script>
  </body>
</html>

<%
function formatCategory(category) {
  return category
    .split("_")
    .join(" ")
    .replace(/\b\w/g, function(letter) {
      return letter.toUpperCase();
    });
}

function scoreLabel(score) {
  if (score >= 8) return "Strong";
  if (score >= 6) return "Needs work";
  return "Priority fix";
}

function scoreClass(score) {
  if (score >= 8) return "score-strong";
  if (score >= 6) return "score-mid";
  return "score-low";
}

function averageCategories(results) {
  const totals = {};
  const counts = {};

  results.forEach(function(result) {
    Object.entries(result.categoryScores).forEach(function(entry) {
      totals[entry[0]] = (totals[entry[0]] || 0) + entry[1];
      counts[entry[0]] = (counts[entry[0]] || 0) + 1;
    });
  });

  const averages = {};

  Object.keys(totals).forEach(function(key) {
    averages[key] = Math.round((totals[key] / counts[key]) * 10) / 10;
  });

  return averages;
}
%>