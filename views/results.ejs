<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <main class="page">
      <div class="topbar">
        <div>
          <p class="eyebrow">Gaming Nectar Intelligence</p>
          <h1>
            <%= siteAudit ? "Full Site Dashboard" : competitorAnalysis ? "Competitor Dashboard" : "Audit Dashboard" %>
          </h1>
        </div>

        <a class="back-link" href="/">Run another audit</a>
      </div>

      <% if (auditRun) { %>
        <section class="saved-run-banner">
          <span>Saved audit</span>
          <p>
            This report is saved in MongoDB. Run ID:
            <strong><%= auditRun._id %></strong>
          </p>
        </section>
      <% } %>

      <% if (siteAudit) { %>
        <section class="dashboard-summary">
          <div class="summary-card hero-score">
            <span>Average score</span>
            <strong><%= siteAudit.summary.averageScore %>/10</strong>
            <p><%= siteAudit.summary.totalPages %> pages audited</p>
          </div>

          <div class="summary-card">
            <span>Total issues</span>
            <strong><%= siteAudit.summary.totalIssues %></strong>
            <p>Across all audited URLs</p>
          </div>

          <div class="summary-card">
            <span>Discovered URLs</span>
            <strong><%= siteAudit.discoveredCount %></strong>
            <p>From sitemap crawl</p>
          </div>
        </section>
      <% } %>

      <% if (competitorAnalysis) { %>
        <section class="dashboard-summary">
          <div class="summary-card hero-score">
            <span>Your page</span>
            <strong><%= competitorAnalysis.primaryScore %>/10</strong>
            <p><%= competitorAnalysis.primaryUrl %></p>
          </div>

          <div class="summary-card">
            <span>Competitors</span>
            <strong><%= competitorAnalysis.competitors.length %></strong>
            <p>Compared head-to-head</p>
          </div>
        </section>
      <% } %>

      <% if (todoSummary) { %>
        <section class="todo-summary-strip">
          <div>
            <span>Total to-dos</span>
            <strong><%= todoSummary.total %></strong>
          </div>
          <div>
            <span>Open</span>
            <strong><%= todoSummary.open %></strong>
          </div>
          <div>
            <span>In progress</span>
            <strong><%= todoSummary.inProgress %></strong>
          </div>
          <div>
            <span>Done</span>
            <strong><%= todoSummary.done %></strong>
          </div>
        </section>
      <% } %>

      <nav class="tabs" data-tabs>
        <button class="active" data-tab-button="overview">Overview</button>
        <button data-tab-button="geo">GEO / AEO</button>
        <button data-tab-button="seo">SEO</button>
        <button data-tab-button="technical">Technical</button>
        <button data-tab-button="linking">Linking</button>
        <button data-tab-button="content">Content</button>
        <button data-tab-button="commercial">Commercial</button>
        <button data-tab-button="pages">Pages</button>
        <button data-tab-button="todos">To-dos</button>

        <% if (competitorAnalysis) { %>
          <button data-tab-button="competitors">Competitors</button>
        <% } %>
      </nav>

      <section class="tab-panel active" data-tab-panel="overview">
        <div class="section-heading">
          <p class="eyebrow">Dashboard</p>
          <h2>Overall performance</h2>
        </div>

        <div class="category-grid">
          <% const overviewScores = siteAudit ? siteAudit.summary.categoryAverages : averageCategories(results); %>
          <% Object.entries(overviewScores).forEach(function(entry) { %>
            <div class="category-item">
              <div>
                <span><%= formatCategory(entry[0]) %></span>
                <div class="score-bar">
                  <i style="width: <%= entry[1] * 10 %>%"></i>
                </div>
              </div>
              <strong><%= entry[1] %>/10</strong>
            </div>
          <% }) %>
        </div>

        <% if (siteAudit) { %>
          <div class="split-grid">
            <section class="panel">
              <h3>Weakest pages</h3>
              <% siteAudit.summary.weakestPages.forEach(function(page) { %>
                <article class="compact-page-row">
                  <strong><%= page.overallScore %>/10</strong>
                  <div>
                    <p><%= page.title || "Untitled page" %></p>
                    <small><%= page.url %></small>
                  </div>
                </article>
              <% }) %>
            </section>

            <section class="panel">
              <h3>Priority issues</h3>
              <% siteAudit.summary.priorityIssues.forEach(function(issue) { %>
                <article class="compact-issue-row">
                  <span><%= formatCategory(issue.category) %></span>
                  <p><%= issue.message %></p>
                  <small><%= issue.url %></small>
                </article>
              <% }) %>
            </section>
          </div>
        <% } %>
      </section>

      <% ["geo", "seo", "technical", "linking", "content"].forEach(function(category) { %>
        <section class="tab-panel" data-tab-panel="<%= category %>">
          <div class="section-heading">
            <p class="eyebrow">Deep dive</p>
            <h2><%= category === "geo" ? "GEO / AEO / Schema" : formatCategory(category) %> analysis</h2>
          </div>

          <% const improvementPlan = siteAudit?.improvementPlans?.[category] || []; %>

          <% if (improvementPlan.length) { %>
            <section class="improvement-panel">
              <div class="section-heading compact">
                <p class="eyebrow">Priority improvements</p>
                <h3>What to improve first</h3>
              </div>

              <div class="improvement-list">
                <% improvementPlan.forEach(function(item) { %>
                  <article class="improvement-card">
                    <div class="improvement-head">
                      <div>
                        <span class="priority-pill"><%= item.priority.label %></span>
                        <h4><%= item.checkName %></h4>
                      </div>

                      <strong><%= item.count %> pages</strong>
                    </div>

                    <div class="improvement-context">
                      <div>
                        <span>Why it matters</span>
                        <p><%= item.context.why %></p>
                      </div>

                      <div>
                        <span>How to improve</span>
                        <p><%= item.context.how %></p>
                      </div>

                      <div>
                        <span>Example</span>
                        <p><%= item.context.example %></p>
                      </div>
                    </div>

                    <% if (item.affectedPages.length) { %>
                      <details class="affected-pages">
                        <summary>View affected pages</summary>

                        <ul>
                          <% item.affectedPages.forEach(function(page) { %>
                            <li>
                              <strong><%= page.title %></strong>
                              <small><%= page.url %></small>
                              <% if (page.evidence) { %>
                                <em>Evidence: <%= page.evidence %></em>
                              <% } %>
                            </li>
                          <% }) %>
                        </ul>
                      </details>
                    <% } %>
                  </article>
                <% }) %>
              </div>
            </section>
          <% } %>

          <div class="deep-list">
            <% results.forEach(function(result) { %>
              <article class="deep-card">
                <div class="deep-card-head">
                  <div>
                    <p class="url"><%= result.url %></p>
                    <h3><%= result.title || "Untitled page" %></h3>
                  </div>

                  <strong><%= result.categoryScores[category] %>/10</strong>
                </div>

                <div class="checks-list">
                  <% (result.categoryDetails[category] || []).forEach(function(check) { %>
                    <% const context = getContext(category, check.name); %>
                    <button
                      type="button"
                      class="check-row check-<%= check.status %>"
                      data-open-check-modal
                      data-audit-run-id="<%= auditRun ? auditRun._id : '' %>"
                      data-return-to="<%= auditRun ? '/audit/' + auditRun._id : '/' %>"
                      data-page-url="<%= result.url %>"
                      data-page-title="<%= result.title || 'Untitled page' %>"
                      data-category="<%= category %>"
                      data-check-name="<%= check.name %>"
                      data-status="<%= check.status %>"
                      data-severity="<%= check.severity %>"
                      data-message="<%= check.message %>"
                      data-recommendation="<%= check.recommendation || '' %>"
                      data-evidence="<%= check.evidence || '' %>"
                      data-why="<%= check.why || context.why %>"
                      data-how="<%= check.how || context.how %>"
                      data-example="<%= check.example || context.example %>"
                      data-business-impact="<%= check.businessImpact || '' %>"
                      data-implementation-hint="<%= check.implementationHint || '' %>"
                      data-expected-impact="<%= check.expectedImpact || '' %>"
                      data-effort="<%= check.effort || '' %>"
                    >
                      <div>
                        <strong><%= check.name %></strong>
                        <p><%= check.message %></p>

                        <% if (check.evidence) { %>
                          <small>Evidence: <%= check.evidence %></small>
                        <% } %>
                      </div>

                      <span class="check-status-pill"><%= check.status %></span>
                      <span class="check-arrow">›</span>
                    </button>
                  <% }) %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>

      <section class="tab-panel" data-tab-panel="commercial">
        <div class="section-heading">
          <p class="eyebrow">Revenue quality</p>
          <h2>Conversion, trust and merchandising</h2>
        </div>

        <% const commercialPlans = [
          ...(siteAudit?.improvementPlans?.conversion || []),
          ...(siteAudit?.improvementPlans?.trust || []),
          ...(siteAudit?.improvementPlans?.merchandising || [])
        ]; %>

        <% if (commercialPlans.length) { %>
          <section class="improvement-panel">
            <div class="section-heading compact">
              <p class="eyebrow">Priority improvements</p>
              <h3>What to improve first commercially</h3>
            </div>

            <div class="improvement-list">
              <% commercialPlans.slice(0, 12).forEach(function(item) { %>
                <article class="improvement-card">
                  <div class="improvement-head">
                    <div>
                      <span class="priority-pill"><%= item.priority.label %></span>
                      <h4><%= item.checkName %></h4>
                    </div>

                    <strong><%= item.count %> pages</strong>
                  </div>

                  <div class="improvement-context">
                    <div>
                      <span>Why it matters</span>
                      <p><%= item.context.why %></p>
                    </div>

                    <div>
                      <span>How to improve</span>
                      <p><%= item.context.how %></p>
                    </div>

                    <div>
                      <span>Example</span>
                      <p><%= item.context.example %></p>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% } %>

        <% ["conversion", "trust", "merchandising"].forEach(function(category) { %>
          <section class="panel spaced-panel">
            <h3><%= formatCategory(category) %></h3>

            <div class="deep-list">
              <% results.forEach(function(result) { %>
                <article class="deep-card">
                  <div class="deep-card-head">
                    <div>
                      <p class="url"><%= result.url %></p>
                      <h3><%= result.title || "Untitled page" %></h3>
                    </div>

                    <strong><%= result.categoryScores[category] %>/10</strong>
                  </div>

                  <div class="checks-list">
                    <% (result.categoryDetails[category] || []).forEach(function(check) { %>
                      <% const context = getContext(category, check.name); %>
                      <button
                        type="button"
                        class="check-row check-<%= check.status %>"
                        data-open-check-modal
                        data-audit-run-id="<%= auditRun ? auditRun._id : '' %>"
                        data-return-to="<%= auditRun ? '/audit/' + auditRun._id : '/' %>"
                        data-page-url="<%= result.url %>"
                        data-page-title="<%= result.title || 'Untitled page' %>"
                        data-category="<%= category %>"
                        data-check-name="<%= check.name %>"
                        data-status="<%= check.status %>"
                        data-severity="<%= check.severity %>"
                        data-message="<%= check.message %>"
                        data-recommendation="<%= check.recommendation || '' %>"
                        data-evidence="<%= check.evidence || '' %>"
                        data-why="<%= check.why || context.why %>"
                        data-how="<%= check.how || context.how %>"
                        data-example="<%= check.example || context.example %>"
                        data-business-impact="<%= check.businessImpact || '' %>"
                        data-implementation-hint="<%= check.implementationHint || '' %>"
                        data-expected-impact="<%= check.expectedImpact || '' %>"
                        data-effort="<%= check.effort || '' %>"
                      >
                        <div>
                          <strong><%= check.name %></strong>
                          <p><%= check.message %></p>

                          <% if (check.evidence) { %>
                            <small>Evidence: <%= check.evidence %></small>
                          <% } %>
                        </div>

                        <span class="check-status-pill"><%= check.status %></span>
                        <span class="check-arrow">›</span>
                      </button>
                    <% }) %>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </section>

      <section class="tab-panel" data-tab-panel="pages">
        <div class="section-heading">
          <p class="eyebrow">Page-level evidence</p>
          <h2>All audited pages</h2>
        </div>

        <section class="results-list">
          <% results.forEach(function(result) { %>
            <article class="result-card">
              <div class="result-header">
                <div>
                  <p class="url"><%= result.url %></p>
                  <h2><%= result.title || "Untitled page" %></h2>

                  <% if (result.metaDescription) { %>
                    <p class="meta-description"><%= result.metaDescription %></p>
                  <% } %>
                </div>

                <div class="score-box <%= scoreClass(result.overallScore) %>">
                  <span class="score"><%= result.overallScore %></span>
                  <span class="score-total">/10</span>
                  <span class="score-label"><%= scoreLabel(result.overallScore) %></span>
                </div>
              </div>

              <div class="insight-strip">
                <% result.insights.forEach(function(insight) { %>
                  <div>
                    <span><%= insight.label %></span>
                    <strong><%= insight.value %></strong>
                    <small><%= insight.note %></small>
                  </div>
                <% }) %>
              </div>

              <details class="details">
                <summary>Issues and recommendations</summary>

                <% if (result.issues.length) { %>
                  <ul class="issue-list">
                    <% result.issues.forEach(function(issue) { %>
                      <li class="severity-<%= issue.severity %>">
                        <div>
                          <span class="issue-category"><%= formatCategory(issue.category) %></span>
                          <strong><%= issue.severity %></strong>
                        </div>

                        <p class="issue-message"><%= issue.message %></p>

                        <% if (issue.recommendation) { %>
                          <p class="issue-recommendation"><%= issue.recommendation %></p>
                        <% } %>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <p>No major issues detected.</p>
                <% } %>
              </details>
            </article>
          <% }) %>
        </section>
      </section>

      <section class="tab-panel" data-tab-panel="todos">
        <div class="section-heading">
          <p class="eyebrow">Action tracker</p>
          <h2>Audit to-do list</h2>
        </div>

        <% if (todos && todos.length) { %>
          <section class="todo-list">
            <% todos.forEach(function(todo) { %>
              <article class="todo-card todo-status-<%= todo.status %>">
                <div class="todo-card-head">
                  <div>
                    <span><%= formatCategory(todo.category) %></span>
                    <h3><%= todo.checkName %></h3>
                    <p><%= todo.pageTitle %></p>
                    <small><%= todo.pageUrl %></small>
                  </div>

                  <strong><%= formatStatus(todo.status) %></strong>
                </div>

                <div class="todo-context">
                  <div>
                    <span>Issue</span>
                    <p><%= todo.message %></p>
                  </div>

                  <div>
                    <span>Recommendation</span>
                    <p><%= todo.recommendation || "No recommendation saved." %></p>
                  </div>

                  <div>
                    <span>Why it matters</span>
                    <p><%= todo.why || "This improvement helps make the page clearer and stronger." %></p>
                  </div>

                  <% if (todo.businessImpact) { %>
                    <div>
                      <span>Business impact</span>
                      <p><%= todo.businessImpact %></p>
                    </div>
                  <% } %>

                  <% if (todo.implementationHint) { %>
                    <div>
                      <span>Implementation hint</span>
                      <p><%= todo.implementationHint %></p>
                    </div>
                  <% } %>

                  <% if (todo.expectedImpact || todo.effort) { %>
                    <div>
                      <span>Impact / Effort</span>
                      <p>
                        <%= todo.expectedImpact ? "Impact: " + todo.expectedImpact : "" %>
                        <%= todo.expectedImpact && todo.effort ? " · " : "" %>
                        <%= todo.effort ? "Effort: " + todo.effort : "" %>
                      </p>
                    </div>
                  <% } %>
                </div>

                <form method="POST" action="/todos/<%= todo._id %>/status" class="todo-status-form">
                  <input type="hidden" name="returnTo" value="<%= auditRun ? '/audit/' + auditRun._id : '/' %>" />

                  <button name="status" value="open" type="submit">Open</button>
                  <button name="status" value="in_progress" type="submit">In progress</button>
                  <button name="status" value="done" type="submit">Done</button>
                  <button name="status" value="ignored" type="submit">Ignore</button>
                </form>
              </article>
            <% }) %>
          </section>
        <% } else { %>
          <section class="panel">
            <h3>No to-dos yet</h3>
            <p>
              Open any SEO, GEO, Technical, Linking, Content or Commercial check,
              then click “Add to to-do list”.
            </p>
          </section>
        <% } %>
      </section>

      <% if (competitorAnalysis) { %>
        <section class="tab-panel" data-tab-panel="competitors">
          <div class="section-heading">
            <p class="eyebrow">Competitor gaps</p>
            <h2>Where competitors are stronger</h2>
          </div>

          <% if (competitorAnalysis.comparison.opportunities.length) { %>
            <div class="opportunity-list">
              <% competitorAnalysis.comparison.opportunities.forEach(function(item) { %>
                <article>
                  <span><%= formatCategory(item.category) %></span>
                  <p><%= item.message %></p>
                  <small><%= item.competitorUrl %></small>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <section class="panel">
              <h3>No major competitor gaps found</h3>
              <p>Your page is not showing major weaknesses against the competitors entered.</p>
            </section>
          <% } %>
        </section>
      <% } %>
    </main>

    <div class="modal-backdrop" data-check-modal hidden>
      <section class="check-modal" role="dialog" aria-modal="true">
        <button class="modal-close" type="button" data-close-check-modal>×</button>

        <div class="modal-top">
          <div>
            <p class="eyebrow" data-modal-category>Category</p>
            <h2 data-modal-check-name>Check name</h2>
            <p data-modal-page-title></p>
            <small data-modal-page-url></small>
          </div>

          <span class="modal-status" data-modal-status>Status</span>
        </div>

        <div class="modal-grid">
          <div>
            <span>What we found</span>
            <p data-modal-message></p>
            <small data-modal-evidence></small>
          </div>

          <div>
            <span>Why it matters</span>
            <p data-modal-why></p>
          </div>

          <div>
            <span>How to improve</span>
            <p data-modal-how></p>
          </div>

          <div>
            <span>Example</span>
            <p data-modal-example></p>
          </div>

          <div data-modal-business-impact-block hidden>
            <span>Business impact</span>
            <p data-modal-business-impact></p>
          </div>

          <div data-modal-implementation-hint-block hidden>
            <span>Implementation hint</span>
            <p data-modal-implementation-hint></p>
          </div>

          <div data-modal-expected-impact-block hidden>
            <span>Expected impact</span>
            <p data-modal-expected-impact></p>
          </div>

          <div data-modal-effort-block hidden>
            <span>Effort</span>
            <p data-modal-effort></p>
          </div>
        </div>

        <form method="POST" action="/todos" class="modal-todo-form">
          <input type="hidden" name="auditRunId" data-field-audit-run-id />
          <input type="hidden" name="returnTo" data-field-return-to />
          <input type="hidden" name="pageUrl" data-field-page-url />
          <input type="hidden" name="pageTitle" data-field-page-title />
          <input type="hidden" name="category" data-field-category />
          <input type="hidden" name="checkName" data-field-check-name />
          <input type="hidden" name="severity" data-field-severity />
          <input type="hidden" name="message" data-field-message />
          <input type="hidden" name="recommendation" data-field-recommendation />
          <input type="hidden" name="evidence" data-field-evidence />
          <input type="hidden" name="why" data-field-why />
          <input type="hidden" name="how" data-field-how />
          <input type="hidden" name="example" data-field-example />
          <input type="hidden" name="businessImpact" data-field-business-impact />
          <input type="hidden" name="implementationHint" data-field-implementation-hint />
          <input type="hidden" name="expectedImpact" data-field-expected-impact />
          <input type="hidden" name="effort" data-field-effort />

          <button type="submit">Add to to-do list</button>
        </form>
      </section>
    </div>

    <script src="/app.js"></script>
  </body>
</html>

<%
function formatCategory(category) {
  return String(category || "")
    .split("_")
    .join(" ")
    .replace(/\b\w/g, function(letter) {
      return letter.toUpperCase();
    });
}

function formatStatus(status) {
  const labels = {
    open: "Open",
    in_progress: "In progress",
    done: "Done",
    ignored: "Ignored"
  };

  return labels[status] || status;
}

function scoreLabel(score) {
  if (score >= 8) return "Strong";
  if (score >= 6) return "Needs work";
  return "Priority fix";
}

function scoreClass(score) {
  if (score >= 8) return "score-strong";
  if (score >= 6) return "score-mid";
  return "score-low";
}

function averageCategories(results) {
  const totals = {};
  const counts = {};

  results.forEach(function(result) {
    Object.entries(result.categoryScores).forEach(function(entry) {
      totals[entry[0]] = (totals[entry[0]] || 0) + entry[1];
      counts[entry[0]] = (counts[entry[0]] || 0) + 1;
    });
  });

  const averages = {};

  Object.keys(totals).forEach(function(key) {
    averages[key] = Math.round((totals[key] / counts[key]) * 10) / 10;
  });

  return averages;
}

function getContext(category, checkName) {
  const contexts = {
    geo: {
      "JSON-LD structured data": {
        why: "Structured data helps search engines and AI systems understand the page as a machine-readable entity.",
        how: "Add valid JSON-LD schema such as Product, Organization, FAQPage, BreadcrumbList, Article or CollectionPage where relevant.",
        example: "A product page should expose product name, description, image, price, availability, brand and reviews where available."
      },
      "Schema type clarity": {
        why: "If schema exists but the type is unclear, search and AI systems may not confidently classify the page.",
        how: "Ensure every JSON-LD block includes a clear @type and validates cleanly.",
        example: "Use @type Product for product pages and @type FAQPage for FAQ sections."
      },
      "JSON-LD validity": {
        why: "Invalid JSON-LD may be ignored entirely by search engines and AI systems.",
        how: "Fix JSON syntax errors and validate structured data before relying on it.",
        example: "Use valid JSON-LD with correct commas, quotes, @context and @type fields."
      },
      "FAQ schema matches visible FAQ": {
        why: "FAQ schema can be risky if the questions and answers are not visibly present on the page.",
        how: "Make sure the same FAQ questions and answers used in JSON-LD are shown on the page. Remove FAQPage schema if the FAQs are hidden.",
        example: "If schema includes 'Is Gaming Nectar sugar free?', that question should also be visible in an FAQ section."
      },
      "Product schema name matches visible product": {
        why: "Product schema should describe the actual visible product. If it does not match, search and AI systems may distrust the data.",
        how: "Use the same product name in Product schema as the visible product title, H1 and product copy.",
        example: "If the page title is 'Gaming Nectar Variety Pack', the Product schema name should also refer to 'Gaming Nectar Variety Pack'."
      },
